#: ../../source/api.rst:2
msgid "API Reference"
msgstr "Referencia de la API"

#: ../../source/api.rst:4
msgid "This section documents the internal modules of Dymion."
msgstr "Esta sección documenta los módulos internos de Dymion."

#: ../../source/api.rst:7
msgid "Core"
msgstr "Núcleo (Core)"

#: dymion.core.vector.Vector:1 of
msgid "A professional 2D/3D Vector class to handle physics coordinates."
msgstr ""

#: dymion.core.vector.Vector.magnitude:1 of
msgid "Return the Euclidean norm of the vector."
msgstr ""

#: dymion.core.vector.Vector.normalize:1 of
msgid "Returns a unit vector in the same direction"
msgstr ""

#: dymion.core.io.export_to_json:1 of
#, python-brace-format
msgid ""
"Exports a list of simulation steps to a JSON file. Example data: "
"[{'time': 0, 'pos': Vector(0,0,0)}, ...]"
msgstr ""

#: ../../source/api.rst:20
msgid "Kinematics"
msgstr "Cinemática"

#: dymion.kinematics.linear.Particle:1 of
msgid "Represents a point mass in space with kinematic properties."
msgstr ""

#: dymion.kinematics.linear.Particle.update:1 of
msgid ""
"Updates the particle's state (position and velocity) after a time "
"interval 'dt'. This uses Euler integration, the standart for simple "
"physics engines."
msgstr ""

#: dymion.kinematics.linear.calculate_position:1 of
msgid ""
"Calculates the final position using the SUVAR equation: r = r0 + v0*t + "
"0.5*a*t^2"
msgstr ""

#: dymion.kinematics.linear.calculate_velocity:1 of
msgid "Calculates the final velocity: v = v0 + a*t"
msgstr ""

#: dymion.kinematics.circular.calculate_angular_position:1 of
msgid ""
"Calculates final angle (radians) using theta = theta 0 + omega0*t + "
"0.5*alpha*t^2"
msgstr ""

#: dymion.kinematics.circular.calculate_angular_velocity:1 of
msgid "Calculates final angular velocity (rad/s): omega = omega0 + alpha*t"
msgstr ""

#: dymion.kinematics.circular.get_centripetal_acceleration:1 of
msgid "a_c = omega^2 * r"
msgstr ""

#: dymion.kinematics.circular.get_tangential_velocity:1 of
msgid "v = omega * r"
msgstr ""

#: dymion.kinematics.circular.polar_to_cartesian:1 of
msgid "Converts polar coordinates (r, theta) to a 2D Vector(x, y)."
msgstr ""

#: ../../source/api.rst:33
msgid "Dynamics"
msgstr "Dinámica"

#: dymion.dynamics.body.Body:1 of
msgid ""
"A Body is a Particle with mass and moment of inertia, allowing for both "
"linear (forces) and rotational (torques) dynamics."
msgstr ""

#: dymion.dynamics.body.Body.apply_force:1 of
msgid "Adds a force vector to the body."
msgstr ""

#: dymion.dynamics.body.Body.apply_torque:1 of
msgid "Adds a torque (rotational force) to the body."
msgstr ""

#: dymion.dynamics.body.Body.clear_forces:1 of
msgid "Clears all linear forces acting on the body."
msgstr ""

#: dymion.dynamics.body.Body.clear_torques:1 of
msgid "Clears all rotational torques acting on the body."
msgstr ""

#: dymion.dynamics.body.Body.update:1 of
msgid "Updates both linear and rotational state based on Newton's Laws."
msgstr ""

#: dymion.dynamics.materials.Material:1 of
msgid "Represents physical properties of a material"
msgstr ""

#: dymion.dynamics.forces.air_resistance:1 of
msgid ""
"Drag Equation: F_d = 1/2 * rho * v^2 * C_d * A Rho is air density, C_d is"
" drag coefficient, A is cross-sectional area."
msgstr ""

#: dymion.dynamics.forces.centrifugal_force:1 of
msgid ""
"Calculates the centrifugal (fictitious) force experienced in a rotating "
"frame. F_f = m * omega^2 * r The force vector points away from the center"
" of rotation (along r)."
msgstr ""

#: dymion.dynamics.forces.centripetal_force:1 of
msgid ""
"Calculates the centripetal force required to keep a body in a circular "
"path. F_c = m * omega^2 * r"
msgstr ""

#: dymion.dynamics.forces.escape_velocity:1 of
msgid ""
"Calculates the minimum speed needed to escape a planet's gravity. v = "
"sqrt(2 * G * M / r)"
msgstr ""

#: dymion.dynamics.forces.friction:1 of
msgid ""
"Calculates the kinetic friction force: F_f = mu * N The force always "
"opposes the direction of velocity"
msgstr ""

#: dymion.dynamics.forces.gravity:1 of
msgid ""
"Calculates the weight force acting on a body: F = m * g By default, it "
"uses Earth's gravity pointing downwards (-Y)"
msgstr ""

#: dymion.dynamics.forces.spring_force:1 of
msgid ""
"Hooke's Law: F = -k * x 'k' is the spring constant, 'displacement' is the"
" vector from equilibrium."
msgstr ""

#: dymion.dynamics.forces.universal_gravitation:1 of
msgid ""
"Calculates the gravitational force between two bodies: F = G * (m1 * m2) "
"/ r^2 The force is returned as a vector acting on body1."
msgstr ""

#: dymion.dynamics.energy.elastic_potential_energy:1 of
msgid "Calculate the elastic potential energy stored in a spring."
msgstr ""

#: dymion.dynamics.energy.elastic_potential_energy:3 of
msgid ""
"Elastic potential energy is the energy stored as a result of deforming an"
" elastic object, such as a spring. Formula: Ee = 1/2 * k * x^2"
msgstr ""

#: dymion.dynamics.energy.elastic_potential_energy
#: dymion.dynamics.energy.gravitational_potential_energy
#: dymion.dynamics.energy.kinetic_energy
#: dymion.dynamics.energy.mechanical_energy dymion.dynamics.energy.power
#: dymion.dynamics.energy.work of
msgid "Parameters"
msgstr ""

#: dymion.dynamics.energy.elastic_potential_energy:7 of
msgid "The spring constant (stiffness) in newtons per meter (N/m)."
msgstr ""

#: dymion.dynamics.energy.elastic_potential_energy:9 of
msgid "The magnitude of displacement from the equilibrium position in meters (m)."
msgstr ""

#: dymion.dynamics.energy.elastic_potential_energy
#: dymion.dynamics.energy.gravitational_potential_energy
#: dymion.dynamics.energy.kinetic_energy
#: dymion.dynamics.energy.mechanical_energy dymion.dynamics.energy.power
#: dymion.dynamics.energy.work of
msgid "Returns"
msgstr ""

#: dymion.dynamics.energy.elastic_potential_energy:12 of
msgid "The elastic potential energy in joules (J)."
msgstr ""

#: dymion.dynamics.energy.elastic_potential_energy
#: dymion.dynamics.energy.gravitational_potential_energy
#: dymion.dynamics.energy.kinetic_energy
#: dymion.dynamics.energy.mechanical_energy dymion.dynamics.energy.power
#: dymion.dynamics.energy.work of
msgid "Return type"
msgstr ""

#: dymion.dynamics.energy.elastic_potential_energy:16
#: dymion.dynamics.energy.gravitational_potential_energy:18
#: dymion.dynamics.energy.kinetic_energy:13
#: dymion.dynamics.energy.mechanical_energy:18 dymion.dynamics.energy.power:15
#: dymion.dynamics.energy.work:15 of
msgid "Examples"
msgstr ""

#: dymion.dynamics.energy.gravitational_potential_energy:1 of
msgid "Calculate the gravitational potential energy of a body."
msgstr ""

#: dymion.dynamics.energy.gravitational_potential_energy:3 of
msgid ""
"Gravitational potential energy is the energy an object possesses due to "
"its position in a gravitational field. Formula: Ep = m * g * h"
msgstr ""

#: dymion.dynamics.energy.gravitational_potential_energy:7 of
msgid "The body object containing mass information."
msgstr ""

#: dymion.dynamics.energy.gravitational_potential_energy:9
#: dymion.dynamics.energy.mechanical_energy:9 of
msgid "The height of the body above the reference point in meters (m)."
msgstr ""

#: dymion.dynamics.energy.gravitational_potential_energy:11
#: dymion.dynamics.energy.mechanical_energy:11 of
msgid "The acceleration due to gravity in m/s^2. Default is G_EARTH (9.81 m/s^2)."
msgstr ""

#: dymion.dynamics.energy.gravitational_potential_energy:14 of
msgid "The gravitational potential energy of the body in joules (J)."
msgstr ""

#: dymion.dynamics.energy.kinetic_energy:1 of
msgid "Calculate the kinetic energy of a body."
msgstr ""

#: dymion.dynamics.energy.kinetic_energy:3 of
msgid ""
"Kinetic energy is the energy possessed by an object due to its motion. "
"Formula: Ek = 1/2 * m * v^2"
msgstr ""

#: dymion.dynamics.energy.kinetic_energy:6
#: dymion.dynamics.energy.mechanical_energy:7 of
msgid "The body object containing mass and velocity information."
msgstr ""

#: dymion.dynamics.energy.kinetic_energy:9 of
msgid "The kinetic energy of the body in joules (J)."
msgstr ""

#: dymion.dynamics.energy.mechanical_energy:1 of
msgid "Calculate the total mechanical energy of a body."
msgstr ""

#: dymion.dynamics.energy.mechanical_energy:3 of
msgid ""
"Mechanical energy is the sum of kinetic energy and potential energy in a "
"system. Formula: E_mech = Ek + Ep"
msgstr ""

#: dymion.dynamics.energy.mechanical_energy:14 of
msgid "The total mechanical energy of the body in joules (J)."
msgstr ""

#: dymion.dynamics.energy.power:1 of
msgid "Calculate the power when work is done over a time interval."
msgstr ""

#: dymion.dynamics.energy.power:3 of
msgid ""
"Power is the rate at which work is done or energy is transferred. "
"Formula: P = W / t"
msgstr ""

#: dymion.dynamics.energy.power:6 dymion.dynamics.energy.work:11 of
msgid "The work done in joules (J)."
msgstr ""

#: dymion.dynamics.energy.power:8 of
msgid "The time interval in seconds (s). Must be positive."
msgstr ""

#: dymion.dynamics.energy.power:11 of
msgid "The power in watts (W). Returns 0.0 if time is zero or negative."
msgstr ""

#: dymion.dynamics.energy.work:1 of
msgid "Calculate the work done by a force on an object."
msgstr ""

#: dymion.dynamics.energy.work:3 of
msgid ""
"Work is the dot product of force and displacement vectors. Formula: W = F"
" · d = |F| * |d| * cos(θ)"
msgstr ""

#: dymion.dynamics.energy.work:6 of
msgid "The force vector acting on the object in newtons (N)."
msgstr ""

#: dymion.dynamics.energy.work:8 of
msgid "The displacement vector in meters (m)."
msgstr ""

#: dymion.dynamics.momentum.elastic_collision_1d:1 of
msgid ""
"Calculates final velocities for a perfect 1D elastic collision. Returns "
"(v1_final, v2_final)"
msgstr ""

#: dymion.dynamics.momentum.impulse:1 of
msgid ""
"Calculates the Impulse (J): J = F * Δt Impulse is also equal to the "
"change in momentum."
msgstr ""

#: dymion.dynamics.momentum.inelastic_collision_1d:1 of
msgid ""
"Calculates the final velocity for a perfectly inelastic collision "
"(objects stick together). v_final = (m1*v1 + m2*v2) / (m1 + m2)"
msgstr ""

#: dymion.dynamics.momentum.linear_momentum:1 of
msgid "Calculates the linear momentum (p): p = m * v"
msgstr ""

#: dymion.dynamics.momentum.resolve_collision_2d:1 of
msgid ""
"Resolves a 2D elastic collision between two bodies. Updates their "
"velocities based on conservation of momentum and energy."
msgstr ""

#: dymion.dynamics.rotational.calculate_torque:1 of
msgid ""
"Calculates Torque (tau) = r x F. r is the vector from the axis of "
"rotation to the point where force is applied."
msgstr ""

#: dymion.dynamics.rotational.inertia_cylinder:1 of
msgid "I = 1/2 * m * r^2"
msgstr ""

#: dymion.dynamics.rotational.inertia_rod_center:1 of
msgid "I = 1/12 * m * L^2"
msgstr ""

#: dymion.dynamics.rotational.inertia_sphere:1 of
msgid "I = 2/5 * m * r^2"
msgstr ""

#: dymion.dynamics.systems.calculate_center_of_mass:1 of
msgid ""
"Calculates the center of mass for a system of multiple bodies. R = "
"(sum(m_i * r_i)) / sum(m_i)"
msgstr ""

#: dymion.dynamics.systems.calculate_total_momentum:1 of
msgid ""
"Calculates the total linear momentum of a system of bodies. P = sum(m_i *"
" v_i)"
msgstr ""

#~ msgid "Momentum & Collisions"
#~ msgstr "Momento y Colisiones"

